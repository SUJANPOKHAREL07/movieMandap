{
  "name": "@cine-gudi/frontend",
  "version": "0.0.1",
  "private": true,
  "nx": {
    "targets": {
      "build": {
        "outputs": [
          "{projectRoot}/dist"
        ]
      }
    }
  },
  "dependencies": {
    "next": "~15.2.4",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-icons": "^5.5.0",
    "@apollo/client": "^3.8.10",
    "graphql": "^16.8.0"
  },
  "scripts": {
    "start": "next start",
    "dev": "PORT=3001 next dev",
    "build": "next build",
    "build:frontend": "yarn build",
    "codegen": "graphql-codegen --config codegen.ts"
  },
  "description": "Frontend application for Cine Gudi. Server-rendered Next app that visualizes the backend GraphQL API.",
  "license": "UNLICENSED"
